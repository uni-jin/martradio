# Azure Speech Service (TTS)
# 1. Azure 포털에서 Speech 리소스 생성 후 키·리전 확인
# 2. 이 파일을 .env.local 로 복사하고 아래 값을 채운 뒤, .env.local 은 git 에 올리지 마세요.
AZURE_SPEECH_KEY=your_speech_resource_key_here
AZURE_SPEECH_REGION=koreacentral

# Google Cloud Text-to-Speech (Chirp 3 HD, 무료 100만 글자/월)
# 서비스 계정 JSON 파일 경로 또는 JSON 문자열 중 하나 설정
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Toss Payments (구독 결제)
# 테스트 키/시크릿 키를 .env.local 에 설정
NEXT_PUBLIC_TOSS_CLIENT_KEY=your_toss_client_key_here
TOSS_SECRET_KEY=your_toss_secret_key_here
# (선택) 웹훅 서명 검증용 보안 키
TOSS_WEBHOOK_SECURITY_KEY=your_toss_webhook_security_key_here
# 정기결제 예정 청구 실행 API 보호용 시크릿 (x-cron-secret)
SUBSCRIPTION_BILLING_CRON_SECRET=your_subscription_billing_cron_secret_here

# 관리자 API (httpOnly 세션 서명 — 운영에서 반드시 강한 값으로 설정)
ADMIN_SESSION_SECRET=your_random_32_plus_char_secret_for_admin_cookie
# 운영에서 ADMIN_PASSWORD 필수. 로컬에서는 미설정 시 개발용 기본값이 사용될 수 있음.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_admin_password_here
